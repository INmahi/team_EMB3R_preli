# Copy to .env for local use (never commit a real .env). On Railway, set these
# in the dashboard "Variables" tab instead. Names only here — no real values.

# Server (Railway injects PORT automatically; default 8000 locally).
PORT=8000

# ===================== LLM layer =====================
# The LLM performs the full analysis (classification, evidence reasoning, drafting).
# It activates only when LLM_ENABLED=true AND at least one provider is configured.
# On any failure the service falls back to the deterministic engine, so it is always
# safe and reachable.
LLM_ENABLED=true

# ---- Recommended: MULTI-PROVIDER (load-balanced, avoids 429) ----
# A JSON array of OpenAI-compatible providers. The service round-robins across them
# and fails over on 429/5xx/timeout, so no single free key gets rate-limited.
# Use DIFFERENT accounts/providers for truly independent rate limits.
# (Put this all on ONE line in the dashboard.)
LLM_PROVIDERS=[{"name":"groq","base_url":"https://api.groq.com/openai/v1","model":"openai/gpt-oss-120b","api_key":"YOUR_GROQ_KEY","timeout":12},{"name":"cerebras","base_url":"https://api.cerebras.ai/v1","model":"gpt-oss-120b","api_key":"YOUR_CEREBRAS_KEY","timeout":12}]

# How long (seconds) to skip a provider after it returns 429/overload.
LLM_PROVIDER_COOLDOWN=30

# ---- Legacy: SINGLE provider (used only if LLM_PROVIDERS is not set) ----
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=openai/gpt-oss-120b
# LLM_API_KEY=
# LLM_TIMEOUT=8
