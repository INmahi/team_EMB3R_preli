# Copy to .env for local use (never commit a real .env). On Railway, set these
# in the dashboard "Variables" tab instead. Names only here — no real values.

# Server (Railway injects PORT automatically; default 8000 locally).
PORT=8000

# ----- Optional LLM layer (OFF by default) -----
# The service is fully functional and safe WITHOUT any of these.
# Set LLM_ENABLED=true and provide a key only if you want LLM-polished text.
LLM_ENABLED=false

# Any OpenAI-compatible endpoint works — pick ONE provider:
#   Groq    : https://api.groq.com/openai/v1            model e.g. llama-3.3-70b-versatile
#   Gemini  : https://generativelanguage.googleapis.com/v1beta/openai   model e.g. gemini-2.0-flash
#   OpenRouter: https://openrouter.ai/api/v1            model e.g. meta-llama/llama-3.3-70b-instruct:free
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=
LLM_TIMEOUT=8
